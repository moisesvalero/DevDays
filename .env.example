# ===========================================
# DevDays — variables de entorno
# ===========================================

# URL pública del sitio (en local déjala como http://localhost:5173)
PUBLIC_SITE_URL=http://localhost:5173

# ---- Supabase (auth + tabla `progreso`) ----
# https://app.supabase.com  →  Project Settings → API
# PUBLIC_SUPABASE_URL=https://xxxxx.supabase.co
# PUBLIC_SUPABASE_ANON_KEY=sb_publishable_xxxxx

# ---- IA del tutor ----
# OpenAI se usa como primario, Gemini como fallback automático.
# Puedes definir solo una si quieres; con ambas tienes failover.
# OPENAI_API_KEY=sk-proj-...
# GEMINI_API_KEY=AIzaSy...

# ---- Whitelist de emails autorizados ----
# Separados por coma. Si está vacío, cualquier email permitido por Supabase entra.
# ALLOWED_EMAILS=tu@email.com,otro@email.com
