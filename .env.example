PUBLIC_SITE_URL=http://localhost:5173

# ===========================================
# DEVDAYS — Portal de estudio
# ===========================================
# Supabase (auth + tabla progreso)
# PUBLIC_SUPABASE_URL=https://xxxxx.supabase.co
# PUBLIC_SUPABASE_ANON_KEY=sb_publishable_xxxxx

# Gemini (corrección y chat del tutor)
# GEMINI_API_KEY=AIzaSy...

# Allowlist de emails que pueden entrar al portal (separados por coma).
# Cualquier email fuera de esta lista será rechazado por el guard del servidor.
# Ejemplo: ALLOWED_EMAILS=tu@email.com,amigo@email.com
# ALLOWED_EMAILS=

# ===========================================
# SANITY CMS (panel para editar contenido)
# ===========================================
# Consiguelos en https://www.sanity.io/manage
# SANITY_PROJECT_ID=tu_project_id
# SANITY_DATASET=production
# SANITY_API_VERSION=2024-01-01
# SANITY_READ_TOKEN=tu_read_token

# ===========================================
# SUPABASE (auth + base de datos)
# ===========================================
# Consiguelos en https://app.supabase.com
# SUPABASE_URL=https://xxxxx.supabase.co
# SUPABASE_ANON_KEY=tu_anon_key

# ===========================================
# SENTRY (tracking de errores en produccion)
# ===========================================
# Consiguelos en https://sentry.io
# El DSN es publico, no hay problema en exponerlo
# PUBLIC_SENTRY_DSN=https://xxxxx@sentry.io/xxxxx

# ===========================================
# RESEND (envio de emails transaccionales)
# ===========================================
# Consiguelos en https://resend.com
# RESEND_API_KEY=re_xxxxx
